import json
import os

FILE_NAME = "registrations.json"


def load_registrations():
    if os.path.exists(FILE_NAME):
        with open(FILE_NAME, "r") as file:
            return json.load(file)
    return []


def save_registrations(registrations):
    with open(FILE_NAME, "w") as file:
        json.dump(registrations, file, indent=4)


def register_participant(registrations):
    print("\n--- Event Registration ---")

    name = input("Enter Name: ")
    email = input("Enter Email: ")
    phone = input("Enter Phone Number: ")

    participant = {
        "Name": name,
        "Email": email,
        "Phone": phone
    }

    registrations.append(participant)
    save_registrations(registrations)

    print("Registration Successful!\n")


def view_registrations(registrations):
    print("\n--- Registered Participants ---")

    if not registrations:
        print("No registrations found.\n")
        return

    for i, participant in enumerate(registrations, start=1):
        print(f"\nParticipant {i}")
        print(f"Name : {participant['Name']}")
        print(f"Email: {participant['Email']}")
        print(f"Phone: {participant['Phone']}")

    print()


def main():
    registrations = load_registrations()

    while True:
        print("===== Event Registration Portal =====")
        print("1. Register Participant")
        print("2. View Registrations")
        print("3. Exit")

        choice = input("Enter your choice: ")

        if choice == "1":
            register_participant(registrations)

        elif choice == "2":
            view_registrations(registrations)

        elif choice == "3":
            print("Thank you for using the portal!")
            break

        else:
            print("Invalid choice. Try again.\n")


if __name__ == "__main__":
    main()
